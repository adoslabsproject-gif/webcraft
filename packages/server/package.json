{
  "name": "@webcraft/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "esbuild src/index.ts --bundle --platform=node --target=node22 --format=esm --outfile=dist/sidecar.mjs --packages=external --banner:js=\"import { createRequire as ___cr } from 'node:module'; const require = ___cr(import.meta.url);\""
  },
  "dependencies": {
    "@duckdb/node-api": "1.5.3-r.1",
    "@libsql/client": "0.17.3",
    "@webcraft/shared": "workspace:*",
    "better-sqlite3": "12.10.0",
    "ioredis-mock": "8.13.1",
    "mongodb-memory-server": "11.1.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "24.12.4",
    "esbuild": "0.28.0",
    "typescript": "6.0.3"
  }
}
